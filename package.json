{
  "name": "apollo-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "bun run build:docs && tsc -p tsconfig.build.json",
    "build:docs": "bun run scripts/build-docs.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "apollo-server": ".",
    "better-auth": "^1.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.0",
    "graphql-tag": "^2.12.6",
    "graphql-upload": "^17.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-tools/schema": "^10.0.31",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphql-upload": "^17.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
