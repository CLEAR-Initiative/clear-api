generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AlertStatus {
  draft
  published
  archived

  @@map("alert_status")
}

enum DetectionStatus {
  raw
  processed
  ignored

  @@map("detection_status")
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  READ

  @@map("notification_status")
}

enum Channel {
  email
  sms
}

enum Frequency {
  immediately
  daily
  weekly
  monthly
}

// ─── Auth (Better Auth) ────────────────────────────────────────────────────

model user {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phoneNumber   String? @map("phone_number")
  image         String?
  role          String  @default("viewer")
  isActive      Boolean @default(true) @map("is_active")

  enableInAppNotification Boolean @default(false) @map("enable_in_app_notification")
  enableEmailNotification Boolean @default(false) @map("enable_email_notification")
  enableSMSNotification   Boolean @default(false) @map("enable_sms_notification")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  sessions session[]
  accounts account[]

  feedback      userAlert[]
  apiKeys       apiKey[]
  notifications notifications[]
  organisations organisationUser[]
}

model session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")
}

// ––– Organisation ––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

model organisation {
  id    String             @id @default(cuid())
  name  String
  users organisationUser[]
}

model organisationUser {
  id             String @id @default(cuid())
  userId         String @map("user_id")
  organisationId String @map("organisation_id")
  role           String @default("viewer")

  user         user         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@map("organisation_user")
}

// ─── Geography ───────────────────────────────────────────────────────────────

model location {
  id       String                                  @id @default(cuid())
  geoId    Int?                                    @map("geonames_id")
  osmId    BigInt?                                 @map("osm_id")
  pCode    String?                                 @map("p_code") @db.VarChar(50)
  geometry Unsupported("geometry(Geometry, 4326)") // use CHECK (GeometryType(geometry) IN ('POINT', 'MULTIPOLYGON'))
  name     String
  level    Int
  parentId String?                                 @map("parent_id")

  parent   location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children location[] @relation("LocationHierarchy")

  alertLinks  alertLocation[]
  sourceLinks sourceLocation[]

  // Reverse relations for signal
  signalOrigins      signal[] @relation("SignalOrigin")
  signalDestinations signal[] @relation("SignalDestination")
  signalLocations    signal[] @relation("SignalLocation")

  // Reverse relations for event
  eventOrigins           event[]                 @relation("EventOrigin")
  eventDestinations      event[]                 @relation("EventDestination")
  eventLocations         event[]                 @relation("EventLocation")
  userAlertSubscriptions userAlertSubscription[]

  @@index([level])
  @@index([parentId])
}

// ─── Data Mining ─────────────────────────────────────────────────────────────

model dataSource {
  id        String   @id @default(cuid())
  name      String
  type      String
  isActive  Boolean  @default(true) @map("is_active")
  baseUrl   String?  @map("base_url")
  infoUrl   String?  @map("info_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sources source[]

  @@index([type])
  @@index([isActive])
  @@map("data_source")
}

model source {
  id         String          @id @default(cuid())
  title      String
  confidence Float?
  status     DetectionStatus @default(raw)
  detectedAt DateTime        @default(now()) @map("detected_at")
  rawData    Json?           @map("raw_data")

  dataSourceId String?     @map("data_source_id")
  source       dataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)

  locations sourceLocation[]
  signal    signal?          @relation("SignalDetection")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, detectedAt])
  @@index([dataSourceId, detectedAt])
}

// ─── Core Product ────────────────────────────────────────────────────────────

model signal {
  id       String @id @default(cuid())
  sourceId String @unique @map("source_id")
  source   source @relation("SignalDetection", fields: [sourceId], references: [id])

  publishedAt DateTime @map("published_at")
  collectedAt DateTime @map("collected_at")

  origin         String?
  originLocation location? @relation("SignalOrigin", fields: [origin], references: [id], onDelete: SetNull)

  destination         String?
  destinationLocation location? @relation("SignalDestination", fields: [destination], references: [id], onDelete: SetNull)

  locationId      String?   @map("location") // In case of signals without origin or destination
  generalLocation location? @relation("SignalLocation", fields: [locationId], references: [id], onDelete: SetNull)

  description String?

  // Reverse side of Event.signals (many-to-many via implicit join)
  events    event[] @relation("EventSignals")
  // Reverse side of Event.primarySignal
  primaryOf event[] @relation("PrimarySignal")
}

model event {
  id String @id @default(cuid())

  signals              signal[] @relation("EventSignals")
  primarySignalId      String?  @map("primary_signal_id")
  primarySignal        signal?  @relation("PrimarySignal", fields: [primarySignalId], references: [id], onDelete: SetNull)
  firstSignalCreatedAt DateTime @map("first_signal")
  lastSignalCreatedAt  DateTime @map("last_signal_created_at")

  status   AlertStatus @default(draft)
  severity Int

  origin         String?
  originLocation location? @relation("EventOrigin", fields: [origin], references: [id], onDelete: SetNull)

  destination         String?
  destinationLocation location? @relation("EventDestination", fields: [destination], references: [id], onDelete: SetNull)

  locationId      String?   @map("location") // In case of events without origin or destination
  generalLocation location? @relation("EventLocation", fields: [locationId], references: [id], onDelete: SetNull)

  description        String?
  eventType          String  @map("event_type")
  populationAffected BigInt? @map("population_affected")
  rank               Float

  isAlert  Boolean @default(false) @map("is_alert")
  metadata Json?

  feedback userAlert[]

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  alertLocations alertLocation[]
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model alertLocation {
  id         String   @id @default(cuid())
  alertId    String   @map("alert_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  alert    event    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  location location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([alertId, locationId])
  @@index([locationId])
  @@map("alert_location")
}

model sourceLocation {
  id         String   @id @default(cuid())
  sourceId   String   @map("source_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  source   source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  location location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([sourceId, locationId])
  @@index([locationId])
  @@map("source_location")
}

model userAlert {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  alertId String @map("alert_id")

  readAt  DateTime? @map("read_at")
  rating  Int?
  comment String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert event @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([alertId])
  @@index([userId, readAt])
  @@map("user_alert")
}

model userAlertSubscription {
  id     String @id @default(cuid())
  userId String @map("user_id")

  location  location @relation(fields: [locationId], references: [id])
  alertType String   @map("alert_type")
  active    Boolean  @default(true)

  channel   Channel
  frequency Frequency

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  locationId String

  @@index([locationId, alertType])
  @@index([locationId])
  @@map("user_alert_subscription")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model apiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  prefix     String
  keyHash    String    @unique @map("key_hash")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_key")
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model featureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flag")
}

// ─── Notifications ———————————————————————————————————————————————————————————

model notifications {
  id               String @id @default(cuid())
  userId           String @map("user_id")
  message          String
  notificationType String @map("notification_type")

  actionUrl  String? @map("action_url")
  actionText String? @map("action_text")

  status                  NotificationStatus  @default(PENDING)
  emailNotificationStatus NotificationStatus? @map("email_notification_status")
  smsNotificationStatus   NotificationStatus? @map("sms_notification_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
