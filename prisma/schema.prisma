generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AlertStatus {
  draft
  published
  archived

  @@map("alert_status")
}

enum DetectionStatus {
  raw
  processed
  ignored

  @@map("detection_status")
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  READ

  @@map("notification_status")
}

enum Channel {
  email
  sms
}

enum Frequency {
  immediately
  daily
  weekly
  monthly
}

// ─── Auth (Better Auth) ────────────────────────────────────────────────────

model user {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phoneNumber   String? @map("phone_number")
  image         String?
  role          String  @default("viewer")
  isActive      Boolean @default(true) @map("is_active")

  inAppNotification Boolean @default(false) @map("in_app_notification")
  emailNotification Boolean @default(false) @map("email_notification")
  smsNotification   Boolean @default(false) @map("sms_notification")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  sessions session[]
  accounts account[]

  alerts                userAlerts[]
  apiKeys               apiKeys[]
  notifications         notifications[]
  organisations         organisationUsers[]
  eventEscaladedByUsers eventEscaladedByUsers[]
  userFeedbacks         userFeedbacks[]
  userComments          userComments[]
  commentTags           commentTags[]
}

model session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")
}

// ––– Organisation ––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

model organisations {
  id    String              @id @default(cuid())
  name  String
  users organisationUsers[]
}

model organisationUsers {
  id             String @id @default(cuid())
  userId         String @map("user_id")
  organisationId String @map("organisation_id")
  role           String @default("viewer")

  user         user          @relation(fields: [userId], references: [id])
  organisation organisations @relation(fields: [organisationId], references: [id])

  @@unique([userId, organisationId])
  @@map("user_to_organisation")
}

// ─── Geography ───────────────────────────────────────────────────────────────

model locations {
  id       String                                  @id @default(cuid())
  geoId    Int?                                    @map("geonames_id")
  osmId    BigInt?                                 @map("osm_id")
  pCode    String?                                 @map("p_code") @db.VarChar(50)
  geometry Unsupported("geometry(Geometry, 4326)") // use CHECK (GeometryType(geometry) IN ('POINT', 'MULTIPOLYGON'))
  name     String
  level    Int
  parentId String?                                 @map("parent_id")

  parent   locations?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children locations[] @relation("LocationHierarchy")

  // alertLinks  alertLocations[]
  // sourceLinks sourceLocations[]

  // Reverse relations for signal
  signalOrigins      signals[] @relation("SignalOrigin")
  signalDestinations signals[] @relation("SignalDestination")
  signalLocations    signals[] @relation("SignalLocation")

  // Reverse relations for event
  eventOrigins           events[]                 @relation("EventOrigin")
  eventDestinations      events[]                 @relation("EventDestination")
  eventLocations         events[]                 @relation("EventLocation")
  userAlertSubscriptions userAlertSubscriptions[]

  @@index([level])
  @@index([parentId])
}

// ─── Data Mining ─────────────────────────────────────────────────────────────

model dataSources {
  id        String   @id @default(cuid())
  name      String
  type      String
  isActive  Boolean  @default(true) @map("is_active")
  baseUrl   String?  @map("url_base")
  infoUrl   String?  @map("url_info")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  signals signals[]

  @@index([type])
  @@index([isActive])
  @@map("data_sources")
}

/**
 * model source {
 * id         String          @id @default(cuid())
 * title      String
 * confidence Float?
 * status     DetectionStatus @default(raw)
 * detectedAt DateTime        @default(now()) @map("detected_at")
 * rawData    Json?           @map("raw_data")
 * dataSourceId String?     @map("data_source_id")
 * source       dataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
 * locations sourceLocation[]
 * signal    signal?          @relation("SignalDetection")
 * createdAt DateTime @default(now()) @map("created_at")
 * updatedAt DateTime @updatedAt @map("updated_at")
 * @@index([status, detectedAt])
 * @@index([dataSourceId, detectedAt])
 * }
 */

// ─── Core Product ────────────────────────────────────────────────────────────

model signals {
  id       String      @id @default(cuid())
  sourceId String      @map("source_id")
  source   dataSources @relation(fields: [sourceId], references: [id])

  rawData     Json     @map("raw_data")
  publishedAt DateTime @map("published_at")
  collectedAt DateTime @default(now()) @map("collected_at")

  url         String?
  title       String?
  description String?

  originId       String?    @map("origin_id")
  originLocation locations? @relation("SignalOrigin", fields: [originId], references: [id])

  destinationId       String?    @map("destination_id")
  destinationLocation locations? @relation("SignalDestination", fields: [destinationId], references: [id])

  locationId      String?         @map("location_id") // In case of signals without origin or destination
  generalLocation locations?      @relation("SignalLocation", fields: [locationId], references: [id])
  userFeedbacks   userFeedbacks[]
  userComments    userComments[]
  signalEvents    signalEvents[]
}

model events {
  id                  String  @id @default(cuid())
  title               String?
  description         String?
  // For LLM
  description_signals Json?

  validFrom            DateTime @default(now()) @map("valid_from")
  validTo              DateTime @map("valid_to")
  firstSignalCreatedAt DateTime @map("first_signal_created_at")
  lastSignalCreatedAt  DateTime @map("last_signal_created_at")

  originId       String?    @map("origin_id")
  originLocation locations? @relation("EventOrigin", fields: [originId], references: [id])

  destinationId       String?    @map("destination_id")
  destinationLocation locations? @relation("EventDestination", fields: [destinationId], references: [id])

  locationId      String?    @map("location_id") // In case of events without origin or destination
  generalLocation locations? @relation("EventLocation", fields: [locationId], references: [id], onDelete: SetNull)

  types                 String[]
  populationAffected    BigInt?                 @map("population_affected")
  rank                  Float
  alerts                alerts[]
  userFeedbacks         userFeedbacks[]
  userComments          userComments[]
  signalEvents          signalEvents[]
  eventEscaladedByUsers eventEscaladedByUsers[]
}

model disasterTypes {
  id            String @id @default(cuid())
  disasterType  String @map("disaster_type")
  disasterClass String @map("disaster_class")
  glideNumber   String @map("glide_number")

  @@map("disaster_types")
}

model alerts {
  id      String      @id @default(cuid())
  eventId String      @map("event_id")
  status  AlertStatus

  event      events       @relation(fields: [eventId], references: [id])
  userAlerts userAlerts[]
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

/**
 * model alertLocations {
 * id         String   @id @default(cuid())
 * alertId    String   @map("alert_id")
 * locationId String   @map("location_id")
 * createdAt  DateTime @default(now()) @map("created_at")
 * updatedAt  DateTime @default(now()) @map("updated_at")
 * alert    alerts    @relation(fields: [alertId], references: [id], onDelete: Cascade)
 * location locations @relation(fields: [locationId], references: [id], onDelete: Cascade)
 * @@unique([alertId, locationId])
 * @@index([locationId])
 * @@map("alert_locations")
 * }
 * model sourceLocations {
 * id         String   @id @default(cuid())
 * sourceId   String   @map("source_id")
 * locationId String   @map("location_id")
 * createdAt  DateTime @default(now()) @map("created_at")
 * source   dataSources   @relation(fields: [sourceId], references: [id])
 * location locations @relation(fields: [locationId], references: [id])
 * @@unique([sourceId, locationId])
 * @@index([locationId])
 * @@map("source_locations")
 * }
 */

// Map alerts received by users
model userAlerts {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  alertId  String    @map("alert_id")
  viewedAt DateTime? @map("viewed_at")

  user  user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert alerts @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([alertId])
  @@index([userId, viewedAt])
  @@map("user_alerts")
}

// Map the events escaladed by users as alerts which can be further escaladed as situation
model eventEscaladedByUsers {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  eventId     String  @map("event_id")
  isSituation Boolean @default(false) @map("is_situation")

  validFrom DateTime @default(now()) @map("valid_from")
  validTo   DateTime @map("valid_to")

  user  user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event events @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_escaladed_by_users")
}

model userFeedbacks {
  id     String @id @default(cuid())
  userId String @map("user_id")

  eventId  String? @map("event_id")
  signalId String? @map("signal_id")
  rating   Int
  // Textual feedback
  text     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal signals? @relation(fields: [signalId], references: [id], onDelete: Cascade)
  event  events?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_feedbacks")
}

model userComments {
  id     String @id @default(cuid())
  userId String @map("user_id")

  eventId  String? @map("event_id")
  signalId String? @map("signal_id")

  comment            String  @map("text")
  isCommentReply     Boolean @map("is_comment_reply")
  repliedToCommentId String? @map("replied_to_comment_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal      signals?      @relation(fields: [signalId], references: [id], onDelete: Cascade)
  event       events?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  commentTags commentTags[]

  @@index([userId])
  @@index([eventId])
  @@index([signalId])
  @@map("user_comments")
}

model commentTags {
  userId    String @map("user_id")
  commentId String @map("comment_id")

  user    user         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment userComments @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_tags")
}

model userAlertSubscriptions {
  id     String @id @default(cuid())
  userId String @map("user_id")

  locationId String    @map("location_id")
  location   locations @relation(fields: [locationId], references: [id])

  alertType String  @map("event_type")
  active    Boolean @default(true)

  channel   Channel
  frequency Frequency

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_alert_subscriptions")
}

model signalEvents {
  id          String   @id @default(cuid())
  signalId    String   @map("signal_id")
  eventId     String   @map("event_id")
  collectedAt DateTime @map("collected_at")

  signal signals @relation(fields: [signalId], references: [id], onDelete: Cascade)
  event  events  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("signal_to_events")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model apiKeys {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  prefix     String
  keyHash    String    @unique @map("key_hash")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_keys")
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model featureFlags {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

// ─── Notifications ———————————————————————————————————————————————————————————

model notifications {
  id               String @id @default(cuid())
  userId           String @map("user_id")
  message          String
  notificationType String @map("notification_type")

  actionUrl  String? @map("action_url")
  actionText String? @map("action_text")

  status                  NotificationStatus  @default(PENDING)
  emailNotificationStatus NotificationStatus? @map("email_notification_status")
  smsNotificationStatus   NotificationStatus? @map("sms_notification_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
