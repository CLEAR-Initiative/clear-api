generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AlertStatus {
  draft
  published
  archived
}

enum DetectionStatus {
  raw
  processed
  ignored
}

enum PointType {
  CENTROID
  GPS
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  READ
}

// ─── Auth (Better Auth) ────────────────────────────────────────────────────

model user {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  phoneNumber   String?
  image         String?
  role          String  @default("viewer")
  isActive      Boolean @default(true)

  enableInAppNotification Boolean @default(false)
  enableEmailNotification Boolean @default(false)
  enableSMSNotification   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  sessions session[]
  accounts account[]

  createdAlerts Alert[]         @relation("AlertCreatedBy")
  feedback      UserAlert[]
  apiKeys       ApiKey[]
  notifications Notifications[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// ─── Geography ───────────────────────────────────────────────────────────────

model Location {
  id        String                                      @id @default(cuid())
  geoId     String                                      @unique
  point     Unsupported("geography(Point,4326)")?
  boundary  Unsupported("geometry(MultiPolygon,4326)")?
  pointType PointType?
  name      String
  level     Int
  parentId  String?

  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Location[] @relation("LocationHierarchy")

  alertLinks     AlertLocation[]
  detectionLinks DetectionLocation[]

  @@index([level])
  @@index([parentId])
}

// ─── Data Mining ─────────────────────────────────────────────────────────────

model DataSource {
  id        String   @id @default(cuid())
  name      String
  type      String
  isActive  Boolean  @default(true)
  baseUrl   String?
  infoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  detections Detection[]
  alerts     Alert[]

  @@index([type])
  @@index([isActive])
}

model Detection {
  id         String          @id @default(cuid())
  title      String
  confidence Float?
  status     DetectionStatus @default(raw)
  detectedAt DateTime        @default(now())
  rawData    Json?

  sourceId String?
  source   DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  locations DetectionLocation[]
  signal    Signal?             @relation("SignalDetection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, detectedAt])
  @@index([sourceId, detectedAt])
}

// ─── Core Product ────────────────────────────────────────────────────────────

model Signal {
  id          String    @id @default(cuid())
  detectionId String    @unique
  detection   Detection @relation("SignalDetection", fields: [detectionId], references: [id])

  // Reverse side of Event.signals (many-to-many via implicit join)
  events    Event[] @relation("EventSignals")
  // Reverse side of Event.primarySignal
  primaryOf Event[] @relation("PrimarySignal")
}

model Event {
  id              String   @id @default(cuid())
  signals         Signal[] @relation("EventSignals")
  primarySignalId String?
  primarySignal   Signal?  @relation("PrimarySignal", fields: [primarySignalId], references: [id], onDelete: SetNull)

  // Reverse sides for Alert relations
  primaryOf Alert[] @relation("PrimaryEvent")
  alerts    Alert[] @relation("AlertEvents")
}

model Alert {
  id          String      @id @default(cuid())
  title       String
  description String
  severity    Int
  status      AlertStatus @default(draft)

  sourceId String?
  source   DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   user?   @relation("AlertCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  primaryEventId String?
  primaryEvent   Event?  @relation("PrimaryEvent", fields: [primaryEventId], references: [id], onDelete: SetNull)

  metadata Json?

  events Event[] @relation("AlertEvents")

  locations AlertLocation[]
  feedback  UserAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([severity])
  @@index([sourceId])
  @@index([createdById])
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model AlertLocation {
  id         String   @id @default(cuid())
  alertId    String
  locationId String
  createdAt  DateTime @default(now())

  alert    Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([alertId, locationId])
  @@index([locationId])
}

model DetectionLocation {
  id          String   @id @default(cuid())
  detectionId String
  locationId  String
  createdAt   DateTime @default(now())

  detection Detection @relation(fields: [detectionId], references: [id], onDelete: Cascade)
  location  Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([detectionId, locationId])
  @@index([locationId])
}

model UserAlert {
  id      String @id @default(cuid())
  userId  String
  alertId String

  readAt  DateTime?
  rating  Int?
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([alertId])
  @@index([userId, readAt])
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String
  keyHash    String    @unique
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ─── Notifications ———————————————————————————————————————————————————————————

model Notifications {
  id               String @id @default(cuid())
  userId           String
  message          String
  notificationType String

  actionUrl  String?
  actionText String?

  status                  NotificationStatus  @default(PENDING)
  emailNotificationStatus NotificationStatus?
  smsNotificationStatus   NotificationStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
