// prisma/schema.prisma
// CLEAR v2 schema (clean restart)
// - Auth: User, Session, Account
// - Core product: Alert, UserAlert
// - Data miner: DataSource, Detection
// - Geography: Location (hierarchy)
// - Multi-location support via join tables: AlertLocation, DetectionLocation
// - Feature flags

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  analyst
  viewer
}

enum AlertStatus {
  draft
  published
  archived
}

enum DetectionStatus {
  raw
  processed
  ignored
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(viewer)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  createdAlerts Alert[]     @relation("AlertCreatedBy")
  feedback      UserAlert[]

  @@index([role])
  @@index([isActive])
}

model Account {
  id                Int       @id @default(autoincrement())
  userId            Int
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Geography ───────────────────────────────────────────────────────────────

model Location {
  id       Int     @id @default(autoincrement())
  geoId    String  @unique
  name     String
  level    Int
  parentId Int?

  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Location[] @relation("LocationHierarchy")

  alertLinks     AlertLocation[]
  detectionLinks DetectionLocation[]

  @@index([level])
  @@index([parentId])
}

// ─── Data Mining ─────────────────────────────────────────────────────────────

model DataSource {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  isActive  Boolean  @default(true)
  baseUrl   String?
  infoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  detections Detection[]
  alerts     Alert[]

  @@index([type])
  @@index([isActive])
}

model Detection {
  id         Int             @id @default(autoincrement())
  title      String
  confidence Float?
  status     DetectionStatus @default(raw)
  detectedAt DateTime        @default(now())
  rawData    Json?

  sourceId Int?
  source   DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  alertId Int?
  alert   Alert? @relation("DetectionAlerts", fields: [alertId], references: [id], onDelete: SetNull)

  // Reverse side of Alert.primaryDetection
  primaryOf Alert[] @relation("PrimaryDetection")

  locations DetectionLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, detectedAt])
  @@index([sourceId, detectedAt])
  @@index([alertId])
}

// ─── Core Product ────────────────────────────────────────────────────────────

model Alert {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  severity    Int
  status      AlertStatus @default(draft)

  sourceId    Int?
  source      DataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  createdById Int?
  createdBy   User? @relation("AlertCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  primaryDetectionId Int?
  primaryDetection   Detection? @relation("PrimaryDetection", fields: [primaryDetectionId], references: [id], onDelete: SetNull)

  metadata Json?

  // Reverse side of Detection.alert
  detections Detection[] @relation("DetectionAlerts")

  locations AlertLocation[]
  feedback  UserAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([severity])
  @@index([sourceId])
  @@index([createdById])
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model AlertLocation {
  id         Int      @id @default(autoincrement())
  alertId    Int
  locationId Int
  createdAt  DateTime @default(now())

  alert    Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([alertId, locationId])
  @@index([locationId])
}

model DetectionLocation {
  id          Int      @id @default(autoincrement())
  detectionId Int
  locationId  Int
  createdAt   DateTime @default(now())

  detection Detection @relation(fields: [detectionId], references: [id], onDelete: Cascade)
  location  Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([detectionId, locationId])
  @@index([locationId])
}

model UserAlert {
  id      Int @id @default(autoincrement())
  userId  Int
  alertId Int

  readAt  DateTime?
  rating  Int?
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([alertId])
  @@index([userId, readAt])
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model FeatureFlag {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
