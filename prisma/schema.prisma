generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AlertStatus {
  draft
  published
  archived

  @@map("alert_status")
}

enum DetectionStatus {
  raw
  processed
  ignored

  @@map("detection_status")
}

enum PointType {
  CENTROID
  GPS

  @@map("point_type")
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  READ

  @@map("notification_status")
}

// ─── Auth (Better Auth) ────────────────────────────────────────────────────

model user {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phoneNumber   String? @map("phone_number")
  image         String?
  role          String  @default("viewer")
  isActive      Boolean @default(true) @map("is_active")

  enableInAppNotification Boolean @default(false) @map("enable_in_app_notification")
  enableEmailNotification Boolean @default(false) @map("enable_email_notification")
  enableSMSNotification   Boolean @default(false) @map("enable_sms_notification")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  sessions session[]
  accounts account[]

  createdAlerts alert[]         @relation("AlertCreatedBy")
  feedback      userAlert[]
  apiKeys       apiKey[]
  notifications notifications[]
}

model session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")
}

// ─── Geography ───────────────────────────────────────────────────────────────

model location {
  id        String                                      @id @default(cuid())
  geoId     String                                      @unique @map("geo_id")
  point     Unsupported("geography(Point,4326)")?
  boundary  Unsupported("geometry(MultiPolygon,4326)")?
  pointType PointType?                                  @map("point_type")
  name      String
  level     Int
  parentId  String?                                     @map("parent_id")

  parent   location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children location[] @relation("LocationHierarchy")

  alertLinks     alertLocation[]
  detectionLinks detectionLocation[]

  @@index([level])
  @@index([parentId])
}

// ─── Data Mining ─────────────────────────────────────────────────────────────

model dataSource {
  id        String   @id @default(cuid())
  name      String
  type      String
  isActive  Boolean  @default(true) @map("is_active")
  baseUrl   String?  @map("base_url")
  infoUrl   String?  @map("info_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  detections detection[]

  @@index([type])
  @@index([isActive])
  @@map("data_source")
}

model detection {
  id         String          @id @default(cuid())
  title      String
  confidence Float?
  status     DetectionStatus @default(raw)
  detectedAt DateTime        @default(now()) @map("detected_at")
  rawData    Json?           @map("raw_data")

  sourceId String?     @map("source_id")
  source   dataSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  locations detectionLocation[]
  signal    signal?             @relation("SignalDetection")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, detectedAt])
  @@index([sourceId, detectedAt])
}

// ─── Core Product ────────────────────────────────────────────────────────────

model signal {
  id          String    @id @default(cuid())
  detectionId String    @unique @map("detection_id")
  detection   detection @relation("SignalDetection", fields: [detectionId], references: [id])

  // Reverse side of Event.signals (many-to-many via implicit join)
  events    event[] @relation("EventSignals")
  // Reverse side of Event.primarySignal
  primaryOf event[] @relation("PrimarySignal")
}

model event {
  id              String   @id @default(cuid())
  signals         signal[] @relation("EventSignals")
  primarySignalId String?  @map("primary_signal_id")
  primarySignal   signal?  @relation("PrimarySignal", fields: [primarySignalId], references: [id], onDelete: SetNull)

  // Reverse sides for Alert relations
  primaryOf alert[] @relation("PrimaryEvent")
  alerts    alert[] @relation("AlertEvents")
}

model alert {
  id          String      @id @default(cuid())
  title       String
  description String
  severity    Int
  status      AlertStatus @default(draft)

  createdById String? @map("created_by_id")
  createdBy   user?   @relation("AlertCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  primaryEventId String? @map("primary_event_id")
  primaryEvent   event?  @relation("PrimaryEvent", fields: [primaryEventId], references: [id], onDelete: SetNull)

  metadata Json?

  events event[] @relation("AlertEvents")

  locations alertLocation[]
  feedback  userAlert[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([severity])
  @@index([createdById])
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model alertLocation {
  id         String   @id @default(cuid())
  alertId    String   @map("alert_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  alert    alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  location location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([alertId, locationId])
  @@index([locationId])
  @@map("alert_location")
}

model detectionLocation {
  id          String   @id @default(cuid())
  detectionId String   @map("detection_id")
  locationId  String   @map("location_id")
  createdAt   DateTime @default(now()) @map("created_at")

  detection detection @relation(fields: [detectionId], references: [id], onDelete: Cascade)
  location  location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([detectionId, locationId])
  @@index([locationId])
  @@map("detection_location")
}

model userAlert {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  alertId String @map("alert_id")

  readAt  DateTime? @map("read_at")
  rating  Int?
  comment String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([alertId])
  @@index([userId, readAt])
  @@map("user_alert")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model apiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  prefix     String
  keyHash    String    @unique @map("key_hash")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_key")
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model featureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flag")
}

// ─── Notifications ———————————————————————————————————————————————————————————

model notifications {
  id               String @id @default(cuid())
  userId           String @map("user_id")
  message          String
  notificationType String @map("notification_type")

  actionUrl  String? @map("action_url")
  actionText String? @map("action_text")

  status                  NotificationStatus  @default(PENDING)
  emailNotificationStatus NotificationStatus? @map("email_notification_status")
  smsNotificationStatus   NotificationStatus? @map("sms_notification_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
