# Application
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL="postgres://user:password@host:port/database"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL=http://localhost:4000

# Frontend URL (for email links — invitations, password reset)
FRONTEND_URL=http://localhost:3000

# Email Provider: "smtp" or "postmark"
EMAIL_PROVIDER=smtp

# SMTP Configuration (when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clear-platform.org

# Postmark Configuration (when EMAIL_PROVIDER=postmark)
# POSTMARK_SERVER_TOKEN=
# POSTMARK_SENDER_EMAIL=

# Celery broker (Redis) — shared with clear-pipeline for task dispatch
CELERY_BROKER_URL=redis://localhost:6379/0

# S3 — Media uploads for manual signals
# For AWS S3:
S3_BUCKET=clear-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For S3-compatible services (MinIO, Cloudflare R2, etc.):
# S3_ENDPOINT=http://localhost:9000

# Global admin seed credentials (env overrides seed defaults)
ADMIN_EMAIL=admin@clear.dev
ADMIN_PASSWORD=password123
